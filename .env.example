# Copy to .env.local and fill in your Supabase project values.
# Both are exposed to the browser (Vite VITE_ prefix). The anon/publishable
# key is safe to ship — access is protected by Row Level Security — but keep
# the real values out of source control.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Server-side only (set in the Vercel dashboard, never VITE_-prefixed).
# Used by api/social-generate.ts — the Redes Sociales batch generator.
# SUPABASE_SERVICE_ROLE_KEY: Supabase project settings > API > service_role.
# CRON_SECRET: any long random string; Vercel Cron sends it automatically as
#   "Authorization: Bearer <CRON_SECRET>" once the env var exists.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
CRON_SECRET=your-long-random-string
